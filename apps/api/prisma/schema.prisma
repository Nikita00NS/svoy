generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MODERATOR
  EDITOR
  SUPPORT
}

enum IntakeType {
  AD_ORDER
  NEWS_PROPOSAL
  APPEAL
  JOB_APPLICATION
  SUPPORT
}

enum IntakeStatus {
  NEW
  IN_REVIEW
  APPROVED
  REJECTED
  CLOSED
}

enum ContentType {
  TEXT
  PHOTO
  VIDEO
  POLL
}

enum ModerationAction {
  DELETE
  WARN
  MUTE
  BAN
}

enum ContentStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  REJECTED
}

model User {
  id               String            @id @default(cuid())
  telegramUserId   BigInt            @unique
  username         String?
  firstName        String?
  lastName         String?
  role             UserRole          @default(MODERATOR)
  isActive         Boolean           @default(true)
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  intakeRequests   IntakeRequest[]
  moderationEvents ModerationEvent[] @relation("ActorModerationEvents")
  supportThreads   SupportThread[]
  auditLogs        AuditLog[]
  sessions         Session[]
}

model Channel {
  id               String            @id @default(cuid())
  telegramId       BigInt?           @unique
  title            String
  handle           String?           @unique
  description      String?
  isActive         Boolean           @default(true)
  postWatermark    String?
  // Новые поля для настроек и статистики
  autoModeration   Boolean           @default(true)
  autoPublishRss   Boolean           @default(false)
  defaultPollAnonymous Boolean       @default(true)
  settingsJson     Json?             // {badWords:[], welcomeText, rules...}
  statsJson        Json?             // {subscribers, views, posts}
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  contentItems     ContentItem[]
  moderationEvents ModerationEvent[]
  rssSources       RssSource[]
}

model Bot {
  id           String   @id @default(cuid())
  username     String   @unique
  tokenRef     String
  webhookPath  String   @unique
  internalKey  String   @unique
  isMaster     Boolean  @default(false)
  isActive     Boolean  @default(true)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model IntakeRequest {
  id                String        @id @default(cuid())
  type              IntakeType
  status            IntakeStatus  @default(NEW)
  telegramChatId    BigInt
  telegramMessageId BigInt?
  title             String?
  text              String?
  mediaFileId       String?
  mediaType         ContentType?
  extraJson         Json?
  userId            String?
  // Новые: коммент модератора и связь с контентом
  moderatorComment  String?
  contentItemId     String?
  deletedAt         DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user              User?         @relation(fields: [userId], references: [id])
  adOrder           AdOrder?
  appeal            Appeal?
  jobApplication    JobApplication?
  supportThread     SupportThread?

  @@index([type, status])
}

model ContentItem {
  id                 String        @id @default(cuid())
  channelId          String?
  sourceRequestId    String?
  title              String?
  body               String?
  mediaFileId        String?
  mediaType          ContentType?
  localMediaPath     String?
  processedMediaPath String?
  watermarkText      String?
  status             ContentStatus @default(DRAFT)
  aiRewrittenText    String?
  publishedMessageId BigInt?
  scheduledFor       DateTime?
  // Новые поля для полного функционала
  moderationComment  String?       // коммент модератора почему отклонено
  pollQuestion       String?
  pollOptions        Json?         // ["Вариант 1","Вариант 2"]
  isAnonymousPoll    Boolean?      @default(true)
  viewsCount         Int?          @default(0)
  extraJson          Json?         // для статистики, кнопок
  deletedAt          DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  channel            Channel?      @relation(fields: [channelId], references: [id])

  @@index([status, scheduledFor])
  @@index([channelId])
}

model ModerationEvent {
  id               String            @id @default(cuid())
  channelId        String?
  actorUserId      String?
  targetTelegramId BigInt
  messageId        BigInt?
  action           ModerationAction
  reason           String?
  createdAt        DateTime          @default(now())

  channel          Channel?          @relation(fields: [channelId], references: [id])
  actorUser        User?             @relation("ActorModerationEvents", fields: [actorUserId], references: [id])
}

model AdOrder {
  id              String   @id @default(cuid())
  intakeRequestId String   @unique
  budget          String?
  desiredDate     String?
  createdAt       DateTime @default(now())

  intakeRequest   IntakeRequest @relation(fields: [intakeRequestId], references: [id], onDelete: Cascade)
}

model Appeal {
  id              String   @id @default(cuid())
  intakeRequestId String   @unique
  decisionNote    String?
  createdAt       DateTime @default(now())

  intakeRequest   IntakeRequest @relation(fields: [intakeRequestId], references: [id], onDelete: Cascade)
}

model JobApplication {
  id              String   @id @default(cuid())
  intakeRequestId String   @unique
  resumeText      String?
  createdAt       DateTime @default(now())

  intakeRequest   IntakeRequest @relation(fields: [intakeRequestId], references: [id], onDelete: Cascade)
}

model SupportThread {
  id              String   @id @default(cuid())
  intakeRequestId String   @unique
  ownerId         String?
  createdAt       DateTime @default(now())

  intakeRequest   IntakeRequest @relation(fields: [intakeRequestId], references: [id], onDelete: Cascade)
  owner           User?         @relation(fields: [ownerId], references: [id])
}

model RssSource {
  id          String   @id @default(cuid())
  title       String
  url         String   @unique
  channelId   String?
  isActive    Boolean  @default(true)
  autoPublish Boolean  @default(false) // авто-публиковать в канал
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channel     Channel? @relation(fields: [channelId], references: [id])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  payloadJson Json?
  createdAt   DateTime @default(now())

  actorUser   User?    @relation(fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}
